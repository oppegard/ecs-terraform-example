{
  "family": "dev-hello-ecs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "REPLACE_AFTER_TERRAFORM_APPLY",
  "taskRoleArn": "REPLACE_AFTER_TERRAFORM_APPLY",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "REPLACE_AFTER_TERRAFORM_APPLY",
      "essential": true,
      "portMappings": [
        {
          "name": "app",
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "APP_ENV",
          "value": "dev"
        },
        {
          "name": "APP_NAME",
          "value": "hello-ecs"
        },
        {
          "name": "PORT",
          "value": "8080"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dev-hello-ecs",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
