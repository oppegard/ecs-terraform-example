{
  "family": "ecs-terraform-example-test-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "REPLACE_AFTER_TERRAFORM_APPLY",
  "taskRoleArn": "REPLACE_AFTER_TERRAFORM_APPLY",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "REPLACE_AFTER_TERRAFORM_APPLY",
      "essential": true,
      "portMappings": [
        {
          "name": "app",
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "APP_ENV",
          "value": "test"
        },
        {
          "name": "APP_NAME",
          "value": "ecs-terraform-example"
        },
        {
          "name": "PORT",
          "value": "8080"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ecs-terraform-example-test",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
