aws_region          = "us-west-2"
project_name        = "ecs-terraform-example"
environment         = "test"
desired_count       = 2
task_cpu            = 512
task_memory         = 1024
container_port      = 8080
health_check_path   = "/health"
bootstrap_image     = "public.ecr.aws/docker/library/python:3.12-slim"
vpc_cidr            = "10.30.0.0/16"
public_subnet_cidrs = ["10.30.1.0/24", "10.30.2.0/24"]
github_repository   = "YOUR_ORG/YOUR_REPO"
github_main_branch  = "main"

# Reuse the shared provider created during bootstrap in another environment.
create_github_oidc_provider = false
github_oidc_provider_arn    = "arn:aws:iam::<account-id>:oidc-provider/token.actions.githubusercontent.com"

extra_tags = {
  Owner = "platform-example"
}
